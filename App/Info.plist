<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>io.unstucknow.app.refresh</string>
	</array>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>UnstuckNow</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>io.unstucknow.app.auth</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>unstuck</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>14</string>
	<key>UIAppFonts</key>
	<array>
		<string>geist_variable.ttf</string>
		<string>instrument_serif_regular.ttf</string>
		<string>instrument_serif_italic.ttf</string>
		<string>ibm_plex_mono_regular.ttf</string>
		<string>ibm_plex_mono_medium.ttf</string>
	</array>
	<!-- Only standard HTTPS/TLS — exempt; skips the TestFlight compliance prompt. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>SUPABASE_ANON_KEY</key>
	<string>$(SUPABASE_ANON_KEY)</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
	</array>
	<key>SUPABASE_HOST</key>
	<string>$(SUPABASE_HOST)</string>
	<key>VOICE_PROXY_URL</key>
	<string>$(VOICE_PROXY_URL)</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Unstuck uses the microphone for the voice assistant (talk to plan your day).</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Unstuck transcribes your speech on-device so you can dictate to the assistant.</string>
	<key>UILaunchScreen</key>
	<dict/>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
